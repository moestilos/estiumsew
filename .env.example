# ────────────────────────────────────────────────────────────
#  VARIABLES DE ENTORNO – estiumsew
#  Copia este archivo a .env y rellena los valores
# ────────────────────────────────────────────────────────────

# Supabase – Project URL y claves (las encuentras en tu dashboard)
# https://app.supabase.com → Settings → API
PUBLIC_SUPABASE_URL=https://TUPROYECTO.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Solo en servidor (NO expongas esta clave en el cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL base del sitio (para callbacks de OAuth)
# En local:     http://localhost:4321
# En Netlify:   https://tudominio.netlify.app
PUBLIC_SITE_URL=http://localhost:4321
