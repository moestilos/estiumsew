---
/**
 * Nav – Barra de navegación
 * Logo: Bebas Neue tipográfico + aguja SVG bold
 * Links: pill hover · IG badge · drawer Bebas Neue
 */
import type { User } from '@supabase/supabase-js';
interface Props { user?: User | null }
const { user } = Astro.props;
---

<header class="nav-wrap">
  <nav>

    <!-- ── Logo ─────────────────────────────────────────── -->
    <a href="/" class="logo" aria-label="estiumsew inicio">
      <!-- Aguja bold + hilo ondulado -->
      <svg class="logo-icon" viewBox="0 0 38 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <!-- Cuerpo de la aguja — grueso, rose -->
        <rect x="4" y="1" width="8" height="30" rx="4" fill="#E03878"/>
        <!-- Ojo de la aguja -->
        <ellipse cx="8" cy="9" rx="2" ry="2.8" fill="white"/>
        <!-- Cola del hilo — lima -->
        <path d="M8 31 Q14 38 8 36" stroke="#7EC021" stroke-width="2.2" fill="none" stroke-linecap="round"/>
        <!-- Onda del hilo — púrpura -->
        <path d="M16 21 Q20 13 25 21 Q30 29 35 21" stroke="#8850C0" stroke-width="2" fill="none" stroke-linecap="round"/>
      </svg>

      <!-- Wordmark tipográfico -->
      <span class="logo-word">
        <span class="logo-estium">ESTIUM</span><span class="logo-sep">·</span><span class="logo-sew">SEW</span>
      </span>
    </a>

    <!-- ── Menú desktop ─────────────────────────────────── -->
    <ul class="nav-menu" id="nav-menu">
      <li><a href="/#sobre">Sobre mí</a></li>
      <li><a href="/#coleccion">Colección</a></li>
      <li><a href="/#proceso">Proceso</a></li>
      <li><a href="/#contacto">Contacto</a></li>
    </ul>

    <!-- ── Derecha ──────────────────────────────────────── -->
    <div class="nav-right">
      {user && (
        <a href="/admin" class="nav-admin">
          <svg viewBox="0 0 24 24" fill="currentColor" width="13" height="13">
            <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
          </svg>
          Admin
        </a>
      )}

      <!-- IG badge pill -->
      <a href="https://instagram.com/estiumsew" target="_blank" rel="noopener" class="nav-ig">
        <svg viewBox="0 0 24 24" fill="currentColor" width="13" height="13">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
        @estiumsew
      </a>

      <!-- Hamburguesa (solo móvil) -->
      <button class="nav-burger" id="nav-burger" aria-label="Abrir menú" aria-expanded="false" aria-controls="nav-drawer">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- ── Drawer móvil ─────────────────────────────────── -->
  <div class="nav-drawer" id="nav-drawer" aria-hidden="true">
    <div class="nav-drawer-inner">

      <!-- Logo en drawer -->
      <div class="drawer-logo">
        <span class="logo-word">
          <span class="logo-estium">ESTIUM</span><span class="logo-sep">·</span><span class="logo-sew">SEW</span>
        </span>
      </div>

      <ul>
        <li><a href="/#sobre"     class="drawer-link">Sobre mí</a></li>
        <li><a href="/#coleccion" class="drawer-link">Colección</a></li>
        <li><a href="/#proceso"   class="drawer-link">Proceso</a></li>
        <li><a href="/#contacto"  class="drawer-link">Contacto</a></li>
        {user && <li><a href="/admin" class="drawer-link drawer-admin">Panel Admin</a></li>}
      </ul>

      <a href="https://instagram.com/estiumsew" target="_blank" rel="noopener" class="drawer-ig">
        <svg viewBox="0 0 24 24" fill="currentColor" width="15" height="15"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        @estiumsew
      </a>
    </div>
  </div>

  <!-- Overlay -->
  <div class="nav-overlay" id="nav-overlay"></div>
</header>

<style>
  /* ── Barra ─────────────────────────────────────────── */
  .nav-wrap {
    position: fixed; top: 0; left: 0; right: 0; z-index: 200;
  }

  nav {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 52px;
    background: transparent;
    backdrop-filter: blur(0px);
    -webkit-backdrop-filter: blur(0px);
    border-bottom: 2px solid transparent;
    transition:
      background .4s ease,
      backdrop-filter .4s ease,
      border-color .4s ease,
      box-shadow .4s ease,
      padding .4s ease;
  }

  .nav-wrap.scrolled nav {
    background: rgba(254,245,249,.95);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-bottom-color: var(--rose);
    box-shadow: 0 4px 32px rgba(224,56,120,.08);
    padding: 13px 52px;
  }

  /* ── Logo ──────────────────────────────────────────── */
  .logo {
    text-decoration: none;
    display: flex; align-items: center; gap: 9px;
    transition: opacity .25s ease;
  }
  .logo:hover { opacity: .82; }

  .logo-icon {
    width: 28px; height: 28px;
    flex-shrink: 0;
    transition: transform .35s cubic-bezier(.16,1,.3,1);
  }
  .logo:hover .logo-icon { transform: rotate(-8deg) scale(1.06); }

  .logo-word {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.6rem;
    letter-spacing: 2px;
    line-height: 1;
    display: flex; align-items: baseline; gap: 2px;
  }
  .logo-estium { color: var(--txt); }
  .logo-sep    { color: var(--lime); font-size: 1.1rem; padding: 0 1px; }
  .logo-sew    { color: var(--rose); }

  /* ── Menú desktop ──────────────────────────────────── */
  .nav-menu {
    display: flex; gap: 4px; list-style: none;
  }
  .nav-menu a {
    font-family: 'Jost', sans-serif;
    font-size: .72rem; font-weight: 600;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--txt-m); text-decoration: none;
    padding: 6px 12px;
    border-radius: 6px;
    transition: background .22s ease, color .22s ease;
  }
  .nav-menu a:hover {
    background: var(--rose);
    color: #fff;
  }

  /* ── Derecha ───────────────────────────────────────── */
  .nav-right { display: flex; align-items: center; gap: 10px; }

  /* Admin link */
  .nav-admin {
    font-family: 'Jost', sans-serif;
    font-size: .7rem; font-weight: 600; letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--sage); text-decoration: none;
    display: flex; align-items: center; gap: 5px;
    padding: 6px 12px;
    border-radius: 6px;
    transition: background .22s, color .22s;
  }
  .nav-admin:hover { background: var(--sage); color: #fff; }

  /* IG badge pill */
  .nav-ig {
    font-family: 'Jost', sans-serif;
    font-size: .7rem; font-weight: 600; letter-spacing: 1px;
    color: var(--rose); text-decoration: none;
    display: flex; align-items: center; gap: 6px;
    padding: 7px 14px;
    border: 1.5px solid rgba(224,56,120,.45);
    border-radius: 40px;
    transition: background .22s ease, color .22s ease, border-color .22s ease,
                transform .22s cubic-bezier(.16,1,.3,1);
  }
  .nav-ig:hover {
    background: var(--rose);
    color: #fff;
    border-color: var(--rose);
    transform: translateY(-2px);
  }
  .nav-ig svg { flex-shrink: 0; fill: currentColor; transition: transform .28s ease; }
  .nav-ig:hover svg { transform: scale(1.12); }

  /* ── Hamburguesa ───────────────────────────────────── */
  .nav-burger {
    display: none;
    flex-direction: column; justify-content: center; align-items: center;
    gap: 5px;
    width: 40px; height: 40px;
    background: transparent;
    border: 2px solid rgba(224,56,120,.4);
    border-radius: 8px; cursor: pointer; padding: 0;
    transition: border-color .2s, background .2s;
  }
  .nav-burger:hover {
    border-color: var(--rose);
    background: rgba(224,56,120,.07);
  }
  .nav-burger span {
    display: block; width: 18px; height: 2px;
    background: var(--txt); border-radius: 2px;
    transition: transform .35s var(--ease-out), opacity .25s ease, width .25s ease;
    transform-origin: center;
  }
  .nav-wrap.menu-open .nav-burger span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-wrap.menu-open .nav-burger span:nth-child(2) { opacity: 0; width: 0; }
  .nav-wrap.menu-open .nav-burger span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ── Drawer móvil ──────────────────────────────────── */
  .nav-drawer {
    position: fixed; top: 0; right: 0; bottom: 0;
    width: min(300px, 85vw);
    background: var(--cream);
    border-left: 3px solid var(--rose);
    box-shadow: -12px 0 48px rgba(224,56,120,.1);
    transform: translateX(100%);
    transition: transform .4s var(--ease-out);
    z-index: 300;
    display: flex; flex-direction: column;
  }
  .nav-wrap.menu-open .nav-drawer { transform: translateX(0); }

  .nav-drawer-inner {
    padding: 36px 32px 40px;
    display: flex; flex-direction: column; height: 100%;
  }

  /* Logo en drawer */
  .drawer-logo {
    margin-bottom: 36px;
    padding-bottom: 20px;
    border-bottom: 2px solid var(--lime);
  }
  .drawer-logo .logo-word { font-size: 1.8rem; }

  /* Links del drawer */
  .nav-drawer-inner ul { list-style: none; display: flex; flex-direction: column; gap: 0; flex: 1; }
  .drawer-link {
    display: flex; align-items: center;
    padding: 14px 0;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.6rem; font-weight: 400; letter-spacing: 2px;
    color: var(--txt); text-decoration: none;
    border-bottom: 1px solid rgba(136,80,192,.1);
    transition: color .2s ease, padding-left .25s var(--ease-out);
    position: relative;
  }
  .drawer-link::before {
    content: '';
    width: 0; height: 100%;
    background: var(--rose);
    position: absolute; left: 0; top: 0;
    transition: width .25s var(--ease-out);
    border-radius: 0 3px 3px 0;
  }
  .drawer-link:hover { color: var(--rose); padding-left: 12px; }
  .drawer-link:hover::before { width: 3px; }

  .drawer-admin {
    font-size: 1rem; color: var(--sage);
  }
  .drawer-admin:hover { color: var(--sage-d); }
  .drawer-admin:hover::before { background: var(--sage); }

  .drawer-ig {
    display: flex; align-items: center; gap: 8px;
    font-family: 'Jost', sans-serif;
    font-size: .75rem; font-weight: 600; letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--rose); text-decoration: none;
    margin-top: 28px;
    padding: 10px 16px;
    border: 1.5px solid rgba(224,56,120,.35);
    border-radius: 40px;
    transition: background .22s, color .22s;
    align-self: flex-start;
  }
  .drawer-ig:hover { background: var(--rose); color: #fff; }

  /* Overlay */
  .nav-overlay {
    position: fixed; inset: 0; z-index: 250;
    background: rgba(24,16,44,.4);
    opacity: 0; pointer-events: none;
    transition: opacity .35s ease;
  }
  .nav-wrap.menu-open .nav-overlay { opacity: 1; pointer-events: all; }

  /* ── Responsive ────────────────────────────────────── */
  @media (max-width: 960px) {
    nav, .nav-wrap.scrolled nav { padding: 15px 24px; }
    .nav-menu  { display: none; }
    .nav-ig    { display: none; }
    .nav-admin { display: none; }
    .nav-burger { display: flex; }
  }
</style>

<script>
  (() => {
    const wrap    = document.querySelector('.nav-wrap')    as HTMLElement;
    const burger  = document.getElementById('nav-burger')  as HTMLButtonElement;
    const drawer  = document.getElementById('nav-drawer')  as HTMLElement;
    const overlay = document.getElementById('nav-overlay') as HTMLElement;
    if (!wrap || !burger) return;

    /* Scroll glass */
    let ticking = false;
    const updateScroll = () => {
      wrap.classList.toggle('scrolled', window.scrollY > 40);
      ticking = false;
    };
    window.addEventListener('scroll', () => {
      if (!ticking) { requestAnimationFrame(updateScroll); ticking = true; }
    }, { passive: true });
    updateScroll();

    /* Hamburguesa */
    const openMenu  = () => {
      wrap.classList.add('menu-open');
      burger.setAttribute('aria-expanded', 'true');
      drawer.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    };
    const closeMenu = () => {
      wrap.classList.remove('menu-open');
      burger.setAttribute('aria-expanded', 'false');
      drawer.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    };

    burger.addEventListener('click', () =>
      wrap.classList.contains('menu-open') ? closeMenu() : openMenu()
    );
    overlay.addEventListener('click', closeMenu);
    drawer.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeMenu(); });
  })();
</script>
