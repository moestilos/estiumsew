---
/**
 * PriceCarousel — Lista de precios animada
 * 4 slides renderizados en código, estilo "PRICE LIST" de marca
 */
const slides = [
  {
    category: 'NECESER',
    bg: '#8850C0',
    accent: '#FF30AA',
    dark: false,
    items: [
      { name: 'Mini Clavel',       price: '8€'  },
      { name: 'Midi Maravilla',    price: '9€'  },
      { name: 'Maxi Crisantelmo', price: '10€' },
      { name: 'Plancha',           price: '10€' },
      { name: 'Estuche',           price: '8€'  },
      { name: 'Porta cepillos',    price: '6€'  },
      { name: 'Monedero',          price: '5€'  },
    ],
  },
  {
    category: 'TOTE BAG',
    bg: '#3A72BC',
    accent: '#C8A8F4',
    dark: false,
    items: [
      { name: 'Basic Astromelia',    price: '9€'  },
      { name: 'BasicMaxi Azucena',   price: '12€' },
      { name: 'Tote Magnolia',       price: '18€' },
      { name: 'ToteMaxi Camelia',    price: '22€' },
      { name: 'Duffle Orquidea',     price: '35€' },
    ],
  },
  {
    category: 'VARIOS',
    bg: '#E03878',
    accent: '#FFE040',
    dark: false,
    items: [
      { name: 'Lanyard Jazmin',          price: '6€'   },
      { name: 'Llavero Peonía',          price: '2,5€' },
      { name: 'Funda portátil Hibisco',  price: '13€'  },
      { name: 'Funda Ebook Violeta',     price: '10€'  },
      { name: 'Funda tablet Petunia',    price: '11€'  },
      { name: 'Porta móvil Amapola',     price: '10€'  },
      { name: 'Neverita Gardenia',       price: '18€'  },
    ],
  },
  {
    category: 'ACCESORIOS EXTRA',
    bg: '#F5C500',
    accent: '#E03878',
    dark: true,
    items: [
      { name: '+ volantes',          price: '+2€'   },
      { name: '+ cremallera',        price: '+2€'   },
      { name: '+ iniciales',         price: '+0,5€' },
      { name: '+ llaverito abalorios', price: '+2€' },
    ],
  },
];
---

<div class="pc" id="price-carousel" tabindex="0" aria-roledescription="carousel">
  {slides.map((s, i) => (
    <div
      class:list={['pc-slide', { active: i === 0 }]}
      data-dark={String(s.dark)}
      style={`background:${s.bg};--accent:${s.accent};--fg:${s.dark ? '#18102C' : '#fff'};--fg-mid:${s.dark ? 'rgba(24,16,44,.5)' : 'rgba(255,255,255,.45)'};--div:${s.dark ? 'rgba(24,16,44,.14)' : 'rgba(255,255,255,.2)'}`}
      aria-label={`Slide ${i + 1}: ${s.category}`}
      role="tabpanel"
    >
      <div class="pc-inner">

        <!-- PRICE / LIST -->
        <div class="pc-title-block">
          <span class="pc-word">PRICE</span>
          <span class="pc-word">LIST</span>
        </div>

        <!-- Categoría -->
        <p class="pc-cat">{s.category}</p>

        <!-- Items -->
        <ul class="pc-list">
          {s.items.map(item => (
            <li>
              <span class="pc-name">{item.name}</span>
              <span class="pc-price">{item.price}</span>
            </li>
          ))}
        </ul>

      </div>

      <!-- Contador -->
      <span class="pc-count" aria-hidden="true">{i + 1} / {slides.length}</span>
    </div>
  ))}

  <!-- Puntos de navegación -->
  <div class="pc-dots" role="tablist" aria-label="Slides">
    {slides.map((s, i) => (
      <button
        class:list={['pc-dot', { active: i === 0 }]}
        data-goto={i}
        aria-label={s.category}
        aria-selected={i === 0}
        role="tab"
        type="button"
      />
    ))}
  </div>
</div>

<style>
  /* ── Wrapper ─────────────────────────────────────────── */
  .pc {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 28px 70px rgba(0,0,0,.18);
    outline: none;
  }
  .pc:focus-visible { box-shadow: 0 28px 70px rgba(0,0,0,.18), 0 0 0 3px rgba(224,56,120,.6); }

  /* ── Slides ──────────────────────────────────────────── */
  .pc-slide {
    position: absolute; inset: 0;
    display: flex; flex-direction: column;
    opacity: 0;
    transform: translateX(28px);
    transition:
      opacity .55s cubic-bezier(.16,1,.3,1),
      transform .55s cubic-bezier(.16,1,.3,1);
    pointer-events: none;
    will-change: opacity, transform;
  }
  .pc-slide.active {
    opacity: 1;
    transform: translateX(0);
    pointer-events: all;
    z-index: 2;
  }
  .pc-slide.exit {
    opacity: 0;
    transform: translateX(-28px);
    z-index: 1;
  }

  /* ── Inner layout ────────────────────────────────────── */
  .pc-inner {
    padding: clamp(22px, 7%, 38px) clamp(20px, 7%, 38px);
    display: flex;
    flex-direction: column;
    height: 100%;
    gap: 0;
  }

  /* ── PRICE · LIST ────────────────────────────────────── */
  .pc-title-block {
    display: flex;
    flex-direction: column;
    line-height: .88;
    margin-bottom: 10px;
    flex-shrink: 0;
  }
  .pc-word {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3.2rem, 10vw, 7rem);
    color: var(--fg);
    letter-spacing: 2px;
    display: block;
  }

  /* ── Categoría ───────────────────────────────────────── */
  .pc-cat {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(.9rem, 2.8vw, 1.4rem);
    letter-spacing: 4px;
    color: var(--accent);
    margin-bottom: 18px;
    flex-shrink: 0;
  }

  /* ── Lista de ítems ──────────────────────────────────── */
  .pc-list {
    list-style: none;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }
  .pc-list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: clamp(7px, 1.4%, 11px) 0;
    border-bottom: 1px solid var(--div);
    font-family: 'Jost', sans-serif;
    font-size: clamp(.68rem, 1.8vw, .86rem);
    font-weight: 500;
    color: var(--fg);
    letter-spacing: .2px;
  }
  .pc-list li:first-child { border-top: 1px solid var(--div); }
  .pc-name { flex: 1; margin-right: 8px; }
  .pc-price { font-weight: 700; flex-shrink: 0; }

  /* ── Contador ────────────────────────────────────────── */
  .pc-count {
    position: absolute; top: 14px; right: 18px; z-index: 5;
    font-family: 'Jost', sans-serif;
    font-size: .65rem; font-weight: 400; letter-spacing: 1.5px;
    color: var(--fg-mid);
  }

  /* ── Puntos ──────────────────────────────────────────── */
  .pc-dots {
    position: absolute; bottom: 16px; left: 50%; transform: translateX(-50%);
    display: flex; align-items: center; gap: 6px; z-index: 20;
  }
  .pc-dot {
    width: 7px; height: 7px;
    background: rgba(255,255,255,.38);
    border: none; border-radius: 4px; cursor: pointer; padding: 0;
    transition:
      background .28s ease,
      width .35s cubic-bezier(.16,1,.3,1);
  }
  .pc-dot.active {
    background: #fff;
    width: 22px;
  }
  .pc--dark .pc-dot { background: rgba(24,16,44,.22); }
  .pc--dark .pc-dot.active { background: #18102c; }
</style>

<script>
  (() => {
    const pc    = document.getElementById('price-carousel') as HTMLElement;
    if (!pc) return;

    const slides = [...pc.querySelectorAll<HTMLElement>('.pc-slide')];
    const dots   = [...pc.querySelectorAll<HTMLButtonElement>('.pc-dot')];
    let cur  = 0;
    let auto: ReturnType<typeof setInterval>;

    function goTo(n: number) {
      const from = cur;
      cur = ((n % slides.length) + slides.length) % slides.length;
      if (from === cur) return;

      slides[from].classList.remove('active');
      slides[from].classList.add('exit');
      slides[cur].classList.add('active');
      setTimeout(() => slides[from].classList.remove('exit'), 580);

      dots.forEach((d, i) => {
        d.classList.toggle('active', i === cur);
        d.setAttribute('aria-selected', String(i === cur));
      });

      // Tema claro/oscuro para flechas y puntos
      pc.classList.toggle('pc--dark', slides[cur].dataset.dark === 'true');
    }

    function restart() {
      clearInterval(auto);
      auto = setInterval(() => goTo(cur + 1), 4200);
    }

    dots.forEach((d, i) => d.addEventListener('click', () => { goTo(i); restart(); }));

    // Swipe táctil
    let sx = 0;
    pc.addEventListener('touchstart', e => { sx = e.touches[0].clientX; }, { passive: true });
    pc.addEventListener('touchend',   e => {
      const dx = e.changedTouches[0].clientX - sx;
      if (Math.abs(dx) > 44) { goTo(dx < 0 ? cur + 1 : cur - 1); restart(); }
    }, { passive: true });

    // Teclado
    pc.addEventListener('keydown', e => {
      if (e.key === 'ArrowLeft')  { goTo(cur - 1); restart(); }
      if (e.key === 'ArrowRight') { goTo(cur + 1); restart(); }
    });

    restart();
  })();
</script>
