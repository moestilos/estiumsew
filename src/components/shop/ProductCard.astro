---
/**
 * ProductCard – Tarjeta de producto rediseñada
 * · Imagen con zoom suave en hover
 * · Badge "Hecho a mano" con blur
 * · Precio con símbolo €
 * · CTA pill con transición fluida
 * · Soporta modo wide (span 2 columnas)
 */
import type { Producto } from '@/lib/types';

interface Props { producto: Producto }
const { producto } = Astro.props;

// Placeholders por categoría
const paletas: Record<string, [string, string, string]> = {
  'Bolsas':     ['#F3EDE4', '#DCCFC4', '👜'],
  'Neceseres':  ['#EDF3EA', '#C8D4C4', '🧴'],
  'Fundas':     ['#EAF0F3', '#C4D4D9', '💻'],
  'Sets':       ['#F3EEF0', '#D4C8D4', '🎁'],
  'Cocina':     ['#F3F1EA', '#D9D4C8', '🧺'],
  'Accesorios': ['#F3EAF0', '#D4C8D4', '🌸'],
};
const [c1, c2, emoji] = paletas[producto.categoria] ?? ['#F3EDE4', '#DCCFC4', '🧵'];

// Formato precio
const precio = Number(producto.precio);
const precioStr = Number.isNaN(precio)
  ? `${producto.precio} €`
  : precio % 1 === 0
    ? `${precio} €`
    : `${precio.toFixed(2)} €`;
---

<article class:list={['card', { 'card-wide': producto.wide }]}>

  <!-- Imagen / placeholder -->
  <div class="card-img">
    {producto.imagen_url ? (
      <img
        src={producto.imagen_url}
        alt={producto.nombre}
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="card-placeholder" style={`background: linear-gradient(135deg, ${c1} 0%, ${c2} 100%)`}>
        <!-- Trama de tela sutil -->
        <svg class="card-texture" viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <defs>
            <pattern id={`tex-${producto.id}`} x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
              <line x1="0" y1="10" x2="20" y2="10" stroke="rgba(180,130,105,.08)" stroke-width="0.8"/>
              <line x1="10" y1="0" x2="10" y2="20" stroke="rgba(180,130,105,.08)" stroke-width="0.8"/>
            </pattern>
          </defs>
          <rect width="80" height="80" fill={`url(#tex-${producto.id})`}/>
        </svg>
        <span class="card-emoji" aria-hidden="true">{emoji}</span>
      </div>
    )}

    <!-- Badge superior -->
    <span class="badge-craft">✦ Hecho a mano</span>

    <!-- Categoría en overlay bottom -->
    <span class="badge-cat">{producto.categoria}</span>
  </div>

  <!-- Contenido -->
  <div class="card-body">
    <h3 class="card-name">{producto.nombre}</h3>

    {producto.descripcion && (
      <p class="card-desc">{producto.descripcion}</p>
    )}

    <div class="card-footer">
      <div class="card-price-wrap">
        <span class="card-price">{precioStr}</span>
      </div>
      <a
        href={`https://wa.me/34695254187?text=${encodeURIComponent(`Hola Fani! Me interesa: ${producto.nombre}`)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="card-cta"
        aria-label={`Pedir ${producto.nombre} por WhatsApp`}
      >
        Pedir
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"
             stroke-linecap="round" stroke-linejoin="round" width="11" height="11" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>
  </div>
</article>

<style>
  /* ── Card base ─────────────────────────────────────── */
  .card {
    background: var(--white);
    border-radius: 18px;
    border: 1px solid rgba(180,130,105,.22);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition:
      box-shadow .4s var(--ease-out),
      transform  .4s var(--ease-out),
      border-color .3s ease;
    will-change: transform;
  }
  .card:hover {
    transform: translateY(-5px);
    box-shadow:
      0 18px 48px rgba(0,0,0,.08),
      0 4px 16px rgba(201,144,122,.1);
    border-color: rgba(201,144,122,.5);
  }

  .card-wide { grid-column: span 2; }

  /* ── Imagen ────────────────────────────────────────── */
  .card-img {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--cream2);
    flex-shrink: 0;
  }
  .card-wide .card-img { aspect-ratio: 2 / 1; }

  .card-img img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform .8s var(--ease-out);
  }
  .card:hover .card-img img { transform: scale(1.07); }

  /* Placeholder con textura de tela */
  .card-placeholder {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
  }
  .card-texture {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    opacity: .6;
  }
  .card-emoji {
    font-size: clamp(2.6rem, 8vw, 4rem);
    position: relative; z-index: 1;
    filter: drop-shadow(0 2px 8px rgba(0,0,0,.08));
    transition: transform .4s var(--ease-out);
  }
  .card:hover .card-emoji { transform: scale(1.08) translateY(-3px); }

  /* Degradado oscuro bottom en hover */
  .card-img::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(46,37,32,.12) 0%, transparent 55%);
    opacity: 0;
    transition: opacity .4s ease;
  }
  .card:hover .card-img::after { opacity: 1; }

  /* ── Badges ────────────────────────────────────────── */
  .badge-craft {
    position: absolute; top: 12px; left: 12px; z-index: 2;
    background: rgba(250,247,242,.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(201,144,122,.22);
    border-radius: 30px;
    padding: 3px 10px;
    font-size: .6rem; font-weight: 500;
    letter-spacing: 1.2px; text-transform: uppercase;
    color: var(--rose-d);
    transition: background .3s, transform .3s var(--ease-out);
  }
  .card:hover .badge-craft {
    background: rgba(250,247,242,.97);
    transform: translateY(-1px);
  }

  .badge-cat {
    position: absolute; bottom: 10px; right: 10px; z-index: 2;
    background: rgba(46,37,32,.55);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 20px;
    padding: 3px 9px;
    font-size: .6rem; font-weight: 500;
    letter-spacing: 1px; text-transform: uppercase;
    color: rgba(250,247,242,.9);
    opacity: 0;
    transition: opacity .3s ease;
  }
  .card:hover .badge-cat { opacity: 1; }

  /* ── Cuerpo ────────────────────────────────────────── */
  .card-body {
    padding: 18px 20px 20px;
    display: flex; flex-direction: column;
    gap: 10px; flex: 1;
  }

  .card-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem; font-weight: 400;
    color: var(--txt); line-height: 1.35;
    transition: color .25s ease;
  }
  .card:hover .card-name { color: var(--rose-d); }

  .card-desc {
    font-size: .78rem; color: var(--txt-l);
    line-height: 1.65;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  /* ── Footer precio + CTA ───────────────────────────── */
  .card-footer {
    display: flex; align-items: center;
    justify-content: space-between;
    margin-top: auto; padding-top: 8px;
    border-top: 1px solid rgba(180,130,105,.1);
  }

  .card-price-wrap { display: flex; align-items: baseline; gap: 2px; }
  .card-price {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem; font-weight: 400;
    color: var(--rose-d);
    letter-spacing: -.3px;
  }

  .card-cta {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 7px 14px; border-radius: 30px;
    font-size: .72rem; font-weight: 500; letter-spacing: .3px;
    color: var(--rose); text-decoration: none;
    border: 1px solid rgba(201,144,122,.3);
    background: transparent;
    transition:
      background .28s var(--ease-out),
      color .28s var(--ease-out),
      border-color .28s var(--ease-out),
      transform .28s var(--ease-out),
      gap .25s var(--ease-out);
    white-space: nowrap;
  }
  .card-cta:hover {
    background: var(--rose);
    color: #fff;
    border-color: var(--rose);
    transform: translateY(-2px);
    gap: 8px;
  }
  .card-cta svg { flex-shrink: 0; transition: transform .25s var(--ease-out); }
  .card-cta:hover svg { transform: translateX(2px); }

  /* ── Móvil ─────────────────────────────────────────── */
  @media (max-width: 540px) {
    .card-body     { padding: 14px 14px 16px; gap: 8px; }
    .card-name     { font-size: .95rem; }
    .card-desc     { font-size: .74rem; -webkit-line-clamp: 2; }
    .card-price    { font-size: 1.05rem; }
    .card-cta      { padding: 6px 11px; font-size: .68rem; }
    .badge-craft   { font-size: .55rem; padding: 2px 8px; }
  }
</style>
