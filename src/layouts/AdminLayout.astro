---
/**
 * AdminLayout – Layout del panel de administración
 * Sidebar moderno con iconos SVG, diseño oscuro elegante.
 */
import type { AdminUser } from '@/lib/auth';

interface Props { title?: string; user: AdminUser; }
const { title = 'Admin · estiumsew', user } = Astro.props;
const path = Astro.url.pathname;

const nav = [
  {
    href: '/admin', label: 'Dashboard', exact: true,
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
      <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
    </svg>`,
  },
  {
    href: '/admin/productos', label: 'Productos', exact: false,
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
      <line x1="3" y1="6" x2="21" y2="6"/>
      <path d="M16 10a4 4 0 01-8 0"/>
    </svg>`,
  },
  {
    href: '/admin/pedidos', label: 'Pedidos', exact: false,
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
      <polyline points="14 2 14 8 20 8"/>
      <line x1="16" y1="13" x2="8" y2="13"/>
      <line x1="16" y1="17" x2="8" y2="17"/>
    </svg>`,
  },
];

function isActive(href: string, exact: boolean) {
  return exact ? path === href : path.startsWith(href);
}

const avatar = user.avatar_url;
const nombre = user.nombre ?? user.email ?? 'Admin';
const inicial = nombre[0].toUpperCase();
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
</head>
<body class="ab">

  <div class="shell">

    <!-- ── Sidebar ─────────────────────────────────── -->
    <aside class="sb">

      <!-- Logo -->
      <a href="/" class="sb-brand" title="Ver tienda pública" target="_blank">
        <div class="sb-logo">
          <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" width="28" height="28">
            <rect width="32" height="32" rx="8" fill="#2E2520"/>
            <line x1="22" y1="5" x2="9" y2="26" stroke="#FAF7F2" stroke-width="2" stroke-linecap="round"/>
            <ellipse cx="21.5" cy="6.2" rx="2.2" ry="1.2" transform="rotate(-25 21.5 6.2)" stroke="#C9907A" stroke-width="1.4" fill="none"/>
            <path d="M20.5 7.5 C17 10 20 13 16 15 C12 17 15 21 11 23" stroke="#C9907A" stroke-width="1.3" stroke-linecap="round" fill="none"/>
            <path d="M9.8 24.5 L8.2 27.2 L10.8 26.5 Z" fill="#FAF7F2"/>
          </svg>
        </div>
        <div>
          <p class="sb-brand-name">estiumsew</p>
          <p class="sb-brand-sub">Panel de admin</p>
        </div>
      </a>

      <!-- Nav -->
      <nav class="sb-nav">
        <p class="sb-nav-label">Menú</p>
        {nav.map(item => (
          <a
            href={item.href}
            class:list={['sb-link', { 'sb-link-active': isActive(item.href, item.exact) }]}
          >
            <span class="sb-link-icon" set:html={item.icon} />
            <span>{item.label}</span>
          </a>
        ))}
      </nav>

      <!-- Spacer -->
      <div class="sb-spacer" />

      <!-- Ver tienda -->
      <a href="/" target="_blank" class="sb-store-link">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        Ver tienda pública
      </a>

      <!-- Usuario -->
      <div class="sb-user">
        <div class="sb-avatar">
          {avatar
            ? <img src={avatar} alt={nombre} referrerpolicy="no-referrer" />
            : <span>{inicial}</span>
          }
        </div>
        <div class="sb-user-info">
          <p class="sb-user-name">{nombre.split(' ')[0]}</p>
          <p class="sb-user-email">{user.email}</p>
        </div>
        <form action="/api/auth/logout" method="POST" class="sb-logout-form">
          <button type="submit" class="sb-logout" title="Cerrar sesión">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
              <polyline points="16 17 21 12 16 7"/>
              <line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
          </button>
        </form>
      </div>
    </aside>

    <!-- ── Main ────────────────────────────────────── -->
    <main class="am">
      <slot />
    </main>

    <!-- ── Barra inferior móvil ────────────────────── -->
    <nav class="mobile-bar">
      {nav.map(item => (
        <a
          href={item.href}
          class:list={['mb-link', { 'mb-link-active': isActive(item.href, item.exact) }]}
        >
          <span set:html={item.icon} />
          <span class="mb-label">{item.label}</span>
        </a>
      ))}
    </nav>

  </div>

</body>
</html>

<style>
  @import '../styles/global.css';

  .ab {
    font-family: 'Inter', sans-serif; font-weight: 300;
    background: var(--admin-bg); color: var(--admin-txt);
    min-height: 100vh; margin: 0;
  }

  .shell {
    display: grid;
    grid-template-columns: 230px 1fr;
    min-height: 100vh;
  }

  /* ── Sidebar ──────────────────────────────────── */
  .sb {
    background: #1e1814;
    border-right: 1px solid rgba(180,130,105,.12);
    display: flex; flex-direction: column;
    padding: 0;
    position: sticky; top: 0; height: 100vh;
    overflow-y: auto;
  }

  .sb-brand {
    display: flex; align-items: center; gap: 12px;
    padding: 22px 20px 20px;
    border-bottom: 1px solid rgba(180,130,105,.1);
    text-decoration: none;
    transition: background .18s;
  }
  .sb-brand:hover { background: rgba(201,144,122,.05); }
  .sb-logo { flex-shrink: 0; }
  .sb-brand-name { font-family: 'Playfair Display', serif; font-size: .95rem; color: #f5ede8; letter-spacing: .3px; }
  .sb-brand-sub  { font-size: .62rem; color: #7A6A62; letter-spacing: 1.8px; text-transform: uppercase; margin-top: 2px; }

  .sb-nav { padding: 20px 12px 8px; display: flex; flex-direction: column; gap: 2px; }
  .sb-nav-label {
    font-size: .6rem; font-weight: 500; letter-spacing: 2px;
    text-transform: uppercase; color: #7A6A62;
    padding: 0 10px; margin-bottom: 8px;
  }

  .sb-link {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 12px; border-radius: 10px;
    text-decoration: none; font-size: .83rem; font-weight: 400;
    color: #a89890;
    transition: background .18s, color .18s;
    position: relative;
  }
  .sb-link-icon { display: flex; align-items: center; flex-shrink: 0; opacity: .7; transition: opacity .18s; }
  .sb-link:hover { background: rgba(201,144,122,.1); color: #f5ede8; }
  .sb-link:hover .sb-link-icon { opacity: 1; }
  .sb-link-active {
    background: rgba(201,144,122,.15);
    color: #C9907A; font-weight: 500;
  }
  .sb-link-active .sb-link-icon { opacity: 1; }
  .sb-link-active::before {
    content: ''; position: absolute; left: 0; top: 25%; bottom: 25%;
    width: 3px; background: #C9907A; border-radius: 0 3px 3px 0;
  }

  .sb-spacer { flex: 1; }

  .sb-store-link {
    display: flex; align-items: center; gap: 8px;
    margin: 0 12px 12px; padding: 9px 12px; border-radius: 9px;
    font-size: .73rem; color: #7A6A62; text-decoration: none;
    border: 1px solid rgba(180,130,105,.1);
    transition: all .18s;
  }
  .sb-store-link:hover { border-color: rgba(201,144,122,.3); color: #C9907A; }

  .sb-user {
    display: flex; align-items: center; gap: 10px;
    padding: 14px 16px;
    border-top: 1px solid rgba(180,130,105,.1);
  }
  .sb-avatar {
    width: 32px; height: 32px; border-radius: 50%; overflow: hidden;
    background: rgba(201,144,122,.25); flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: .82rem; font-weight: 600; color: #C9907A;
  }
  .sb-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .sb-user-info { flex: 1; min-width: 0; overflow: hidden; }
  .sb-user-name  { font-size: .8rem; font-weight: 500; color: #f5ede8; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .sb-user-email { font-size: .64rem; color: #7A6A62; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .sb-logout-form { flex-shrink: 0; }
  .sb-logout {
    background: transparent; border: 1px solid rgba(180,130,105,.15);
    border-radius: 8px; padding: 7px;
    color: #7A6A62; cursor: pointer; display: flex; align-items: center;
    transition: all .18s;
  }
  .sb-logout:hover { border-color: rgba(200,112,112,.4); color: #c87070; }

  /* ── Main ─────────────────────────────────────── */
  .am {
    padding: 36px 44px;
    overflow-y: auto; min-height: 100vh;
  }

  /* ── Móvil ────────────────────────────────────── */
  .mobile-bar { display: none; }

  @media (max-width: 768px) {
    .shell { grid-template-columns: 1fr; padding-bottom: 70px; }
    .sb    { display: none; }
    .am    { padding: 22px 18px; }

    .mobile-bar {
      display: flex;
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 200;
      background: #1e1814;
      border-top: 1px solid rgba(180,130,105,.15);
      padding: 8px 0 max(8px, env(safe-area-inset-bottom));
    }
    .mb-link {
      flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px;
      padding: 6px 0; text-decoration: none;
      color: #7A6A62; font-size: .62rem; letter-spacing: .5px;
      transition: color .18s;
    }
    .mb-link svg { width: 20px; height: 20px; }
    .mb-link-active { color: #C9907A; }
    .mb-label { display: block; }
  }
</style>
