---
/**
 * AdminLayout – Layout del panel de administración
 * Sidebar oscuro con navegación, protección de rutas por middleware
 */
import type { User } from '@supabase/supabase-js';

interface Props {
  title?: string;
  user: User;
}

const { title = 'Admin · estiumsew', user } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/admin',           label: 'Dashboard',  icon: '◈' },
  { href: '/admin/productos', label: 'Productos',   icon: '✦' },
  { href: '/admin/pedidos',   label: 'Pedidos',     icon: '◎' },
];
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Inter:wght@300;400;500&display=swap"
    rel="stylesheet"
  />
</head>
<body class="admin-body">

  <div class="admin-shell">

    <!-- ── Sidebar ─────────────────────────────────────── -->
    <aside class="sidebar">
      <a href="/" class="sidebar-brand" title="Ver tienda pública">
        <svg viewBox="0 0 180 40" fill="none">
          <line x1="6" y1="8" x2="6" y2="32" stroke="#C9907A" stroke-width="1.5" stroke-linecap="round"/>
          <ellipse cx="6" cy="7" rx="2.5" ry="3.5" stroke="#C9907A" stroke-width="1.2" fill="none"/>
          <line x1="4.8" y1="6.5" x2="7.2" y2="6.5" stroke="#C9907A" stroke-width="1" stroke-linecap="round"/>
          <path d="M6 32 Q10 38 6 36" stroke="#C9907A" stroke-width="1" fill="none" stroke-linecap="round"/>
          <path d="M9 20 Q15 13 20 20 Q25 27 30 20 Q35 13 40 20" stroke="#B5C4B1" stroke-width="1.2" fill="none" stroke-linecap="round"/>
          <text x="46" y="26" font-family="Georgia,'Playfair Display',serif" font-size="17" fill="#f5ede8" letter-spacing="0.5">estium</text>
          <text x="115" y="26" font-family="Georgia,'Playfair Display',serif" font-size="17" font-style="italic" fill="#C9907A" letter-spacing="0.5">sew</text>
          <circle cx="43" cy="23" r="1.8" fill="#E8C4B8"/>
        </svg>
        <span class="sidebar-brand-sub">Panel de admin</span>
      </a>

      <nav class="sidebar-nav">
        {navItems.map(item => (
          <a
            href={item.href}
            class:list={['sidebar-link', { active: currentPath === item.href }]}
          >
            <span class="sidebar-icon">{item.icon}</span>
            {item.label}
          </a>
        ))}
      </nav>

      <div class="sidebar-footer">
        <div class="sidebar-user">
          <div class="sidebar-avatar">
            {(user.user_metadata?.avatar_url)
              ? <img src={user.user_metadata.avatar_url} alt="Avatar" referrerpolicy="no-referrer" />
              : <span>{(user.user_metadata?.full_name ?? user.email ?? 'A')[0].toUpperCase()}</span>
            }
          </div>
          <div class="sidebar-user-info">
            <p class="sidebar-user-name">{user.user_metadata?.full_name ?? 'Admin'}</p>
            <p class="sidebar-user-email">{user.email}</p>
          </div>
        </div>
        <form action="/api/auth/logout" method="POST">
          <button type="submit" class="btn-logout">Cerrar sesión</button>
        </form>
      </div>
    </aside>

    <!-- ── Contenido principal ──────────────────────────── -->
    <main class="admin-main">
      <slot />
    </main>

  </div>

</body>
</html>

<style>
  @import '../styles/global.css';

  .admin-body {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    background: var(--admin-bg);
    color: var(--admin-txt);
    min-height: 100vh;
  }

  .admin-shell {
    display: grid;
    grid-template-columns: 240px 1fr;
    min-height: 100vh;
  }

  /* ── Sidebar ─────────────────────────────────────────── */
  .sidebar {
    background: var(--admin-surface);
    border-right: 1px solid var(--admin-border);
    display: flex; flex-direction: column;
    padding: 28px 0;
    position: sticky; top: 0; height: 100vh;
    overflow-y: auto;
  }

  .sidebar-brand {
    display: flex; flex-direction: column; gap: 4px;
    padding: 0 24px 28px;
    border-bottom: 1px solid var(--admin-border);
    text-decoration: none;
  }
  .sidebar-brand svg { height: 30px; width: auto; }
  .sidebar-brand-sub {
    font-size: .65rem; letter-spacing: 2px; text-transform: uppercase;
    color: var(--admin-txt-m);
    margin-top: 6px;
  }

  .sidebar-nav {
    flex: 1; padding: 20px 12px;
    display: flex; flex-direction: column; gap: 4px;
  }

  .sidebar-link {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 14px;
    border-radius: 8px;
    text-decoration: none;
    font-size: .83rem; font-weight: 400;
    color: var(--admin-txt-m);
    transition: all .18s;
  }
  .sidebar-link:hover { background: rgba(201,144,122,.12); color: var(--admin-txt); }
  .sidebar-link.active { background: rgba(201,144,122,.18); color: var(--rose); }
  .sidebar-icon { font-size: .9rem; opacity: .7; }

  .sidebar-footer {
    padding: 20px 16px 0;
    border-top: 1px solid var(--admin-border);
  }

  .sidebar-user {
    display: flex; align-items: center; gap: 10px;
    padding: 12px 8px; margin-bottom: 10px;
  }
  .sidebar-avatar {
    width: 34px; height: 34px; border-radius: 50%;
    overflow: hidden; background: var(--rose);
    display: flex; align-items: center; justify-content: center;
    font-size: .85rem; font-weight: 500; color: #fff;
    flex-shrink: 0;
  }
  .sidebar-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .sidebar-user-name  { font-size: .8rem; font-weight: 500; color: var(--admin-txt); }
  .sidebar-user-email { font-size: .7rem; color: var(--admin-txt-m); }

  .btn-logout {
    width: 100%; padding: 9px; border-radius: 8px;
    background: rgba(255,255,255,.05);
    border: 1px solid var(--admin-border);
    color: var(--admin-txt-m); font-size: .78rem;
    cursor: pointer; transition: all .18s;
  }
  .btn-logout:hover { border-color: var(--rose); color: var(--rose); }

  /* ── Main ────────────────────────────────────────────── */
  .admin-main {
    padding: 40px 48px;
    overflow-y: auto;
  }

  @media (max-width: 768px) {
    .admin-shell { grid-template-columns: 1fr; }
    .sidebar { position: fixed; bottom: 0; top: auto; height: auto; width: 100%; flex-direction: row; z-index: 100; }
    .sidebar-brand, .sidebar-footer { display: none; }
    .sidebar-nav { flex-direction: row; padding: 8px; justify-content: space-around; }
    .admin-main { padding: 24px 20px 80px; }
  }
</style>
