---
/**
 * BaseLayout – Layout raíz de la tienda pública
 * Incluye: meta tags, fuentes, canvas de fondo animado, partículas
 */
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'estiumsew · Fani Mateos',
  description = '🫶🏼 Productos hechos a mano con máquina de coser · Pedidos personalizados · Entregas en Sevilla, Barcelona y Lleida',
  ogImage = '/og-image.jpg',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="referrer" content="no-referrer" />
  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- Open Graph -->
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:type"        content="website" />
  <meta name="twitter:card"       content="summary_large_image" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Fuentes -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Inter:wght@300;400;500&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <!-- Fondo: blobs suaves -->
  <canvas id="bg-canvas"></canvas>
  <div class="bg-stitch"></div>

  <!-- Overlay de transición de página -->
  <div id="page-veil"></div>

  <div class="wrap">
    <slot />
  </div>

  <!-- Canvas animado: blobs pastel suaves, sin parpadeos -->
  <script>
    (() => {
      const canvas = document.getElementById('bg-canvas') as HTMLCanvasElement;
      const ctx    = canvas.getContext('2d')!;

      const blobs = [
        { x: .15, y: .25, r: .42, color: 'rgba(232,196,184,', speed: .00008, phase: 0   },
        { x: .82, y: .18, r: .35, color: 'rgba(181,196,177,', speed: .00006, phase: 1.2 },
        { x: .5,  y: .65, r: .48, color: 'rgba(221,211,199,', speed: .00007, phase: 2.4 },
        { x: .12, y: .78, r: .30, color: 'rgba(201,144,122,', speed: .00005, phase: 0.8 },
        { x: .85, y: .72, r: .34, color: 'rgba(181,196,177,', speed: .00006, phase: 3.6 },
      ];

      let W = 0, H = 0;

      function resize() {
        W = canvas.width  = window.innerWidth;
        H = canvas.height = window.innerHeight;
      }

      function draw(ts: number) {
        ctx.clearRect(0, 0, W, H);
        for (const b of blobs) {
          const ox = Math.sin(ts * b.speed + b.phase) * 0.025;
          const oy = Math.cos(ts * b.speed * 0.8 + b.phase) * 0.02;
          const cx = (b.x + ox) * W;
          const cy = (b.y + oy) * H;
          const r  = b.r * Math.min(W, H);
          const g  = ctx.createRadialGradient(cx, cy, 0, cx, cy, r);
          g.addColorStop(0,   b.color + '.13)');
          g.addColorStop(.5,  b.color + '.06)');
          g.addColorStop(1,   b.color + '0)');
          ctx.fillStyle = g;
          ctx.beginPath();
          ctx.arc(cx, cy, r, 0, Math.PI * 2);
          ctx.fill();
        }
      }

      let last = 0;
      function loop(ts: number) {
        if (ts - last > 50) { draw(ts); last = ts; }
        requestAnimationFrame(loop);
      }

      window.addEventListener('resize', resize);
      resize();
      requestAnimationFrame(loop);
    })();
  </script>

  <!-- Transición de página: fade-in al entrar, fade-out al salir -->
  <script>
    (() => {
      const veil = document.getElementById('page-veil') as HTMLElement;
      if (!veil) return;

      // Fade-in al cargar
      veil.style.opacity = '1';
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          veil.style.transition = 'opacity .45s ease';
          veil.style.opacity    = '0';
          setTimeout(() => { veil.style.pointerEvents = 'none'; }, 460);
        });
      });

      // Fade-out al salir (solo links internos, no externos ni admin)
      document.addEventListener('click', (e) => {
        const a = (e.target as Element).closest('a');
        if (!a) return;
        const href = a.getAttribute('href');
        if (!href) return;
        // Solo links internos que no sean anclas ni externos
        if (href.startsWith('http') || href.startsWith('#') || href.startsWith('/admin') || href.startsWith('/login')) return;
        if (a.target === '_blank') return;

        e.preventDefault();
        veil.style.pointerEvents = 'all';
        veil.style.transition    = 'opacity .35s ease';
        veil.style.opacity       = '1';
        setTimeout(() => { window.location.href = href; }, 360);
      });
    })();
  </script>

  <!-- Tracker de visitas -->
  <script>
    fetch('/api/visita', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ pagina: window.location.pathname }),
    }).catch(() => {});
  </script>

  <!-- Scroll reveal — observa .reveal, .reveal-left y .reveal-right -->
  <script>
    (() => {
      const targets = document.querySelectorAll('.reveal, .reveal-left, .reveal-right');
      if (!targets.length) return;

      const io = new IntersectionObserver(
        (entries) => entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            io.unobserve(e.target);
          }
        }),
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );

      targets.forEach(el => io.observe(el));
    })();
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
