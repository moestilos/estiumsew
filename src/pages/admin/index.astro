---
/**
 * admin/index.astro – Dashboard del panel de administración
 */
import AdminLayout from '@/layouts/AdminLayout.astro';
import VisitsChart from '@/components/admin/VisitsChart';
import { sql } from '@/lib/db';

const user = Astro.locals.user!;

const hoy    = new Date(); hoy.setHours(0, 0, 0, 0);
const hace30 = new Date(hoy); hace30.setDate(hace30.getDate() - 30);
const ayer   = new Date(hoy); ayer.setDate(ayer.getDate() - 1);

const [
  stats,
  recientes,
  visHoy,
  visAyer,
  vis30d,
] = await Promise.all([
  sql`
    select
      (select count(*)::int from productos) as total_productos,
      (select count(*)::int from productos where activo = true) as productos_activos,
      (select count(*)::int from pedidos) as total_pedidos,
      (select count(*)::int from pedidos where estado = 'pendiente') as pendientes
  `,
  sql`
    select id, nombre_cliente, estado, creado_en
    from pedidos order by creado_en desc limit 5
  `,
  sql`select count(*)::int as n from visitas where creado_en >= ${hoy.toISOString()}`,
  sql`select count(*)::int as n from visitas where creado_en >= ${ayer.toISOString()} and creado_en < ${hoy.toISOString()}`,
  sql`select count(*)::int as n from visitas where creado_en >= ${hace30.toISOString()}`,
]);

const { total_productos, productos_activos, total_pedidos, pendientes } =
  (stats as any[])[0] ?? { total_productos: 0, productos_activos: 0, total_pedidos: 0, pendientes: 0 };

const totalProductos   = total_productos   as number;
const productosActivos = productos_activos as number;
const totalPedidos     = total_pedidos     as number;
const visitasHoy       = (visHoy  as any[])[0]?.n ?? 0;
const visitasAyer      = (visAyer as any[])[0]?.n ?? 0;
const visitas30d       = (vis30d  as any[])[0]?.n ?? 0;

function fmtDate(d: string) {
  return new Intl.DateTimeFormat('es-ES', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }).format(new Date(d));
}

const estadoBadge: Record<string, { color: string; bg: string }> = {
  pendiente:  { color: '#C9907A', bg: 'rgba(201,144,122,.12)' },
  confirmado: { color: '#8FA88A', bg: 'rgba(143,168,138,.12)' },
  en_proceso: { color: '#B5C4B1', bg: 'rgba(181,196,177,.12)' },
  enviado:    { color: '#90A8C9', bg: 'rgba(144,168,201,.12)' },
  entregado:  { color: '#a89890', bg: 'rgba(168,152,144,.12)' },
  cancelado:  { color: '#7A6A62', bg: 'rgba(122,106,98,.12)'  },
};

const nombre = (user.nombre ?? 'Fani').split(' ')[0];
const hora   = new Date().getHours();
const saludo = hora < 13 ? 'Buenos días' : hora < 20 ? 'Buenas tardes' : 'Buenas noches';
---

<AdminLayout title="Dashboard · estiumsew" user={user}>
  <div class="dash">

    <!-- Bienvenida -->
    <div class="dash-welcome">
      <div>
        <p class="dash-saludo">{saludo} ✦</p>
        <h1>{nombre} </h1>
        <p class="dash-sub">Aquí tienes un resumen de tu tienda</p>
      </div>
      <a href="/admin/productos" class="btn-cta">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Nuevo producto
      </a>
    </div>

    <!-- Stats grid -->
    <div class="stats-grid">
      <a href="/admin/productos" class="stat-card" style="--accent:#C9907A">
        <div class="stat-icon-wrap">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
          </svg>
        </div>
        <div class="stat-body">
          <span class="stat-value">{productosActivos ?? 0}</span>
          <span class="stat-label">Productos visibles</span>
        </div>
        <span class="stat-sub">{totalProductos ?? 0} total</span>
      </a>

      <a href="/admin/pedidos" class="stat-card" style="--accent:#8FA88A">
        <div class="stat-icon-wrap">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
          </svg>
        </div>
        <div class="stat-body">
          <span class="stat-value">{totalPedidos ?? 0}</span>
          <span class="stat-label">Pedidos totales</span>
        </div>
        <span class="stat-sub">{pendientes ?? 0} pendientes</span>
      </a>

      {(pendientes ?? 0) > 0 && (
        <a href="/admin/pedidos" class="stat-card stat-card-alert" style="--accent:#E8A87C">
          <div class="stat-icon-wrap">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
          </div>
          <div class="stat-body">
            <span class="stat-value">{pendientes ?? 0}</span>
            <span class="stat-label">Por atender</span>
          </div>
          <span class="stat-sub stat-alert-sub">¡Revisar ahora!</span>
        </a>
      )}

      <div class="stat-card" style="--accent:#90A8C9">
        <div class="stat-icon-wrap">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
          </svg>
        </div>
        <div class="stat-body">
          <span class="stat-value">{visitasHoy ?? 0}</span>
          <span class="stat-label">Visitas hoy</span>
        </div>
        <span class="stat-sub">{visitasAyer ?? 0} ayer · {visitas30d ?? 0} en 30d</span>
      </div>
    </div>

    <!-- Gráfica de visitas -->
    <VisitsChart client:load />

    <!-- Últimas consultas -->
    <div class="dash-section">
      <div class="dash-section-head">
        <div>
          <h2>Últimas consultas</h2>
          <p class="section-desc">Las {(recientes as any[])?.length ?? 0} más recientes</p>
        </div>
        <a href="/admin/pedidos" class="link-ver">Ver todas →</a>
      </div>

      {(!recientes || (recientes as any[]).length === 0) ? (
        <div class="empty-state">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.3">
            <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
          </svg>
          <p>Aún no hay pedidos. Aparecerán aquí cuando lleguen.</p>
        </div>
      ) : (
        <div class="recientes">
          {(recientes as any[]).map(p => (
            <div class="reciente-row">
              <div class="rec-avatar">
                {p.nombre_cliente[0].toUpperCase()}
              </div>
              <div class="rec-info">
                <p class="rec-name">{p.nombre_cliente}</p>
                <p class="rec-date">{fmtDate(p.creado_en)}</p>
              </div>
              <span
                class="rec-estado"
                style={`color:${estadoBadge[p.estado]?.color ?? '#a89890'}; background:${estadoBadge[p.estado]?.bg ?? 'rgba(168,152,144,.1)'}`}
              >
                {p.estado.replace('_', ' ')}
              </span>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Acciones rápidas -->
    <div class="dash-section">
      <h2>Acciones rápidas</h2>
      <div class="quick-grid">
        <a href="/admin/productos" class="quick-card">
          <div class="quick-icon" style="--qi:#C9907A">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/>
            </svg>
          </div>
          <div>
            <p>Gestionar productos</p>
            <small>Añadir, editar o eliminar artículos</small>
          </div>
          <svg class="quick-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
        <a href="/admin/pedidos" class="quick-card">
          <div class="quick-icon" style="--qi:#8FA88A">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/>
            </svg>
          </div>
          <div>
            <p>Ver pedidos</p>
            <small>Gestiona consultas y estados</small>
          </div>
          <svg class="quick-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
        <a href="/" target="_blank" class="quick-card">
          <div class="quick-icon" style="--qi:#90A8C9">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
          </div>
          <div>
            <p>Ver tienda pública</p>
            <small>Cómo la ven tus clientes</small>
          </div>
          <svg class="quick-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
        <a href="https://instagram.com/estiumsew" target="_blank" rel="noopener" class="quick-card">
          <div class="quick-icon" style="--qi:#C9B1C4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
            </svg>
          </div>
          <div>
            <p>Instagram</p>
            <small>@estiumsew</small>
          </div>
          <svg class="quick-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      </div>
    </div>

  </div>
</AdminLayout>

<style>
  .dash { display: flex; flex-direction: column; gap: 24px; }

  .dash-welcome {
    display: flex; justify-content: space-between; align-items: flex-start;
    flex-wrap: wrap; gap: 16px; padding-bottom: 8px;
  }
  .dash-saludo { font-size: .7rem; letter-spacing: 2.5px; text-transform: uppercase; color: #C9907A; margin-bottom: 6px; }
  .dash-welcome h1 { font-family: 'Playfair Display',serif; font-size: 2.2rem; font-weight: 400; color: #f5ede8; line-height: 1.1; }
  .dash-sub { font-size: .82rem; color: #a89890; margin-top: 6px; }
  .btn-cta {
    display: flex; align-items: center; gap: 8px;
    background: #C9907A; color: #fff;
    border: none; border-radius: 12px; padding: 12px 22px;
    font-size: .83rem; font-weight: 500; text-decoration: none;
    transition: background .2s, transform .18s; white-space: nowrap;
  }
  .btn-cta:hover { background: #A8705C; transform: translateY(-2px); }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 14px;
  }
  .stat-card {
    background: #241e1a;
    border: 1px solid rgba(180,130,105,.15);
    border-radius: 16px; padding: 20px 22px;
    text-decoration: none;
    display: flex; flex-direction: column; gap: 4px;
    transition: border-color .25s, transform .25s, box-shadow .25s;
    position: relative; overflow: hidden;
  }
  .stat-card::before {
    content: ''; position: absolute; top: 0; left: 0;
    width: 3px; height: 100%;
    background: var(--accent, #C9907A);
    border-radius: 3px 0 0 3px;
    opacity: 0; transition: opacity .25s;
  }
  .stat-card:hover { border-color: rgba(201,144,122,.35); transform: translateY(-2px); box-shadow: 0 8px 28px rgba(0,0,0,.15); }
  .stat-card:hover::before { opacity: 1; }
  .stat-card-alert { border-color: rgba(232,168,124,.25); animation: pulse-border 2.5s ease-in-out infinite; }
  @keyframes pulse-border {
    0%,100% { border-color: rgba(232,168,124,.2); }
    50%      { border-color: rgba(232,168,124,.5); }
  }
  .stat-icon-wrap {
    width: 34px; height: 34px; border-radius: 9px;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(180,130,105,.15);
    display: flex; align-items: center; justify-content: center;
    color: var(--accent, #C9907A); margin-bottom: 10px;
  }
  .stat-body { display: flex; flex-direction: column; gap: 2px; }
  .stat-value { font-family: 'Playfair Display',serif; font-size: 2.2rem; color: #f5ede8; line-height: 1; }
  .stat-label { font-size: .72rem; color: #a89890; font-weight: 500; }
  .stat-sub   { font-size: .68rem; color: #7A6A62; margin-top: 8px; }
  .stat-alert-sub { color: #E8A87C; }

  .dash-section {
    background: #241e1a;
    border: 1px solid rgba(180,130,105,.15);
    border-radius: 16px; padding: 24px 28px;
  }
  .dash-section-head {
    display: flex; justify-content: space-between; align-items: flex-start;
    margin-bottom: 20px;
  }
  .dash-section h2 {
    font-family: 'Playfair Display',serif; font-size: 1.15rem;
    font-weight: 400; color: #f5ede8;
  }
  .section-desc { font-size: .72rem; color: #7A6A62; margin-top: 3px; }
  .link-ver { font-size: .76rem; color: #C9907A; text-decoration: none; white-space: nowrap; margin-top: 4px; }
  .link-ver:hover { text-decoration: underline; }

  .empty-state {
    display: flex; flex-direction: column; align-items: center; gap: 10px;
    padding: 32px 0; color: #7A6A62; font-size: .82rem; text-align: center;
  }

  .recientes { display: flex; flex-direction: column; gap: 2px; }
  .reciente-row {
    display: flex; align-items: center; gap: 14px;
    padding: 12px 10px; border-radius: 10px;
    transition: background .18s;
  }
  .reciente-row:hover { background: rgba(255,255,255,.03); }
  .rec-avatar {
    width: 38px; height: 38px; border-radius: 50%;
    background: rgba(201,144,122,.15); color: #C9907A;
    display: flex; align-items: center; justify-content: center;
    font-size: .88rem; font-weight: 600; flex-shrink: 0;
  }
  .rec-info { flex: 1; min-width: 0; }
  .rec-name { font-size: .84rem; font-weight: 500; color: #f5ede8; }
  .rec-date { font-size: .7rem; color: #7A6A62; margin-top: 2px; }
  .rec-estado {
    font-size: .68rem; font-weight: 500; text-transform: capitalize;
    padding: 4px 10px; border-radius: 20px; white-space: nowrap;
  }

  .quick-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 10px; margin-top: 16px; }
  @media (max-width: 600px) { .quick-grid { grid-template-columns: 1fr; } }
  .quick-card {
    display: flex; align-items: center; gap: 14px;
    padding: 14px 16px; border-radius: 12px;
    background: rgba(255,255,255,.025);
    border: 1px solid rgba(180,130,105,.12);
    text-decoration: none; transition: all .2s;
  }
  .quick-card:hover { background: rgba(201,144,122,.07); border-color: rgba(201,144,122,.3); transform: translateX(2px); }
  .quick-icon {
    width: 38px; height: 38px; border-radius: 10px; flex-shrink: 0;
    background: rgba(255,255,255,.04); border: 1px solid rgba(180,130,105,.15);
    display: flex; align-items: center; justify-content: center;
    color: var(--qi, #C9907A);
  }
  .quick-card p     { font-size: .83rem; font-weight: 500; color: #f5ede8; }
  .quick-card small { font-size: .71rem; color: #7A6A62; margin-top: 2px; display: block; }
  .quick-arrow { color: #7A6A62; margin-left: auto; flex-shrink: 0; transition: transform .2s; }
  .quick-card:hover .quick-arrow { transform: translateX(3px); color: #C9907A; }

  @media (max-width: 600px) {
    .stats-grid { grid-template-columns: 1fr 1fr; }
    .stat-value { font-size: 1.8rem; }
    .dash-welcome h1 { font-size: 1.7rem; }
  }
</style>
