---
/**
 * admin/pedidos.astro – Gestión de pedidos / consultas recibidas
 */
import AdminLayout from '@/layouts/AdminLayout.astro';
import OrderTable from '@/components/admin/OrderTable';
import { sql } from '@/lib/db';
import type { Pedido, PedidoItem } from '@/lib/types';

const user = Astro.locals.user!;

const pedidos = (await sql`
  select * from pedidos
  order by creado_en desc
`) as Pedido[];

if (pedidos.length) {
  const ids = pedidos.map(p => p.id);
  const items = (await sql`
    select * from pedido_items where pedido_id = any(${ids}::uuid[])
  `) as PedidoItem[];
  for (const p of pedidos) {
    p.pedido_items = items.filter(i => i.pedido_id === p.id);
  }
}
---

<AdminLayout title="Pedidos · estiumsew" user={user}>
  <OrderTable
    client:only="react"
    initialOrders={pedidos ?? []}
  />
</AdminLayout>
